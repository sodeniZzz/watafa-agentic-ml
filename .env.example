# Copy as .env and fill in your values

API_KEY=YOUR_API_KEY
# Base URL for the LLM API (OpenRouter by default, can be changed to any OpenAI-compatible endpoint)
API_URL=https://openrouter.ai/api/v1
MODEL_NAME=minimax/minimax-m2.7
EMBEDDING_MODEL_NAME=openai/text-embedding-3-small

# Kaggle competition slug (e.g. "mws-ai-agents-2026")
KAGGLE_COMPETITION=KAGGLE_COMPETITION
# Kaggle credentials (https://www.kaggle.com/settings -> API -> Create Legacy Api Key)
KAGGLE_USERNAME=YOUR_KAGGLE_USERNAME
KAGGLE_KEY=YOUR_KAGGLE_API_KEY